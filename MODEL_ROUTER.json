{
  "version": "1.3",
  "last_updated": "2026-03-10",
  "description": "Agent-to-Model mapping. Haiku is default for new subagents. Atlas validates model availability before task dispatch.",

  "global_defaults": {
    "primary_fallback": "claude-sonnet-4-20250514",
    "secondary_fallback": "claude-opus-4-5-20251101",
    "timeout_seconds": 60,
    "retry_attempts": 3
  },

  "subagent_default": {
    "model": "anthropic/claude-haiku-4-5-20251001",
    "note": "All new subagents spawn with Haiku unless explicitly overridden in the task payload."
  },

  "agent_routing": {
    "atlas": {
      "primary_model": "claude-haiku-4-5-20251001",
      "fallback_model": "claude-sonnet-4-20250514",
      "role": "Gatekeeper - validates all routing decisions. Default to Haiku. Request Sonnet or Opus for heavy reasoning.",
      "min_confidence_threshold": 0.85
    },
    "olg": {
      "primary_model": "claude-haiku-4-5-20251001",
      "fallback_model": "claude-sonnet-4-20250514",
      "role": "Writer - content drafting"
    },
    "rob_c": {
      "primary_model": "claude-haiku-4-5-20251001",
      "fallback_model": "claude-sonnet-4-20250514",
      "role": "Engagement - evaluates content against audience rules"
    },
    "hunter": {
      "primary_model": "claude-haiku-4-5-20251001",
      "fallback_model": "claude-sonnet-4-20250514",
      "role": "Sales - prospect engagement"
    },
    "pulse": {
      "primary_model": "google/gemini-2.5-flash",
      "fallback_model": "claude-sonnet-4-20250514",
      "role": "Research - web search and synthesis",
      "requires_web_search": true
    },
    "dr_frankl": {
      "primary_model": "phi-4-mini-local",
      "fallback_model": "claude-haiku-4-5-20251001",
      "role": "Life Coach - pattern matching against BRYAN_PROFILE.md"
    },
    "ledger": {
      "primary_model": "claude-sonnet-4-20250514",
      "fallback_model": "claude-haiku-4-5-20251001",
      "role": "Data & Analytics - structuring and analysis"
    },
    "voss": {
      "primary_model": "phi-4-mini-local",
      "fallback_model": "claude-haiku-4-5-20251001",
      "role": "Devil's Advocate - critique and risk assessment"
    },
    "spark": {
      "primary_model": "claude-sonnet-4-20250514",
      "fallback_model": "claude-haiku-4-5-20251001",
      "role": "Ideas & Concepts - synthesis across domains"
    },
    "bob_the_builder": {
      "primary_model": "ollama/qwen3.5-coder:27b",
      "fallback_model": "claude-sonnet-4-20250514",
      "tertiary_fallback": "claude-haiku-4-5-20251001",
      "role": "Code & Technical Build",
      "note": "Primary: Local Qwen3.5-Coder (offline reasoning). Fallback: Claude Sonnet (API). Max reliability via local-first strategy."
    },
    "detective_niessen": {
      "primary_model": "phi-4-mini-local",
      "fallback_model": "claude-haiku-4-5-20251001",
      "role": "Security & Defense - audit against FILE_AUDIT_LOG.jsonl"
    }
  },

  "model_availability": {
    "claude-haiku-4-5-20251001":  { "status": "active", "type": "api", "last_checked": "2026-03-05" },
    "claude-opus-4-5-20251101":   { "status": "active", "type": "api", "last_checked": "2026-03-05" },
    "claude-sonnet-4-20250514":   { "status": "active", "type": "api", "last_checked": "2026-03-05" },
    "ollama/phi-4-mini:latest":   { "status": "active", "type": "local", "last_checked": "2026-03-05" },
    "ollama/deepseek-r1:14b":     { "status": "active", "type": "local", "last_checked": "2026-03-05" },
    "ollama/qwen3.5-coder:27b":   { "status": "active", "type": "local", "local_model_name": "qwen3.5:27b-q4_K_M", "size_gb": 17, "last_checked": "2026-03-10" },
    "google/gemini-2.5-flash":    { "status": "active", "type": "api", "api_key_env": "GEMINI_API_KEY", "last_checked": "2026-03-05" }
  },

  "model_availability_check": {
    "enabled": true,
    "validator": "atlas",
    "check_interval_seconds": 60,
    "log_to": "FILE_AUDIT_LOG.jsonl"
  },

  "rate_limit_rules": {
    "claude_haiku": {
      "threshold_tokens_per_hour": 200000,
      "action_on_breach": "switch_to_fallback"
    },
    "claude_opus": {
      "threshold_tokens_per_hour": 50000,
      "action_on_breach": "switch_to_fallback"
    },
    "claude_sonnet": {
      "threshold_tokens_per_hour": 100000,
      "action_on_breach": "switch_to_fallback"
    },
    "phi_4_mini_local": {
      "threshold": "unlimited",
      "action_on_error": "switch_to_fallback"
    },
    "deepseek_r1_local": {
      "threshold": "unlimited",
      "action_on_error": "switch_to_fallback"
    },
    "qwen3.5_coder_27b_local": {
      "threshold": "unlimited",
      "action_on_error": "switch_to_fallback",
      "note": "Local reasoning model for code generation + technical tasks"
    }
  },

  "model_switch_log": [],

  "audit_trail": {
    "log_file": "FILE_AUDIT_LOG.jsonl",
    "track_model_switches": true,
    "track_fallback_triggers": true
  }
}
