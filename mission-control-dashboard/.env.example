# Dashboard Password Protection
# Set this in Vercel environment variables
DASHBOARD_PASSWORD=your-secure-password-here

# ── Model Status / Runtime Config ──────────────────────────────────────────────

# Path to openclaw.json on the host machine.
# On local dev, GET /api/runtime-config reads this file to show LIVE runtime state.
# On Vercel (VERCEL=1), this is ignored — the endpoint reads data/agent-models.json instead.
# Default: ~/.openclaw/openclaw.json
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# ── File API / Workspace ────────────────────────────────────────────────────────

# Local dev workspace path (where BLOCKERS.json, TOKEN_USAGE.jsonl, etc. live)
# Default: ./data/vault (relative to this directory)
WORKSPACE_PATH=/path/to/.openclaw/workspace

# ── Vercel / GitHub write-back ─────────────────────────────────────────────────
# Only needed on Vercel deployments for the Memory Vault save functionality.
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=BF8thRev/AtlasNorth
# GITHUB_BRANCH=main
