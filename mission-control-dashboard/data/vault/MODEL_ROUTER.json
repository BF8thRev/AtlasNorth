    "enabled": true,
    "validator": "atlas",
    "check_interval_seconds": 60,
    "log_to": "FILE_AUDIT_LOG.jsonl"
  },

  "rate_limit_rules": {
    "gpt_4o": {
      "threshold_tokens_per_hour": 200000,
      "action_on_breach": "switch_to_fallback",
      "cost_tracking": true
    },
    "gpt_4_turbo": {
      "threshold_tokens_per_hour": 150000,
      "action_on_breach": "switch_to_fallback",
      "cost_tracking": true
    },
    "gpt_3_5_turbo": {
      "threshold_tokens_per_hour": 300000,
      "action_on_breach": "switch_to_fallback",
      "cost_tracking": true
    },
    "claude_haiku": {
      "threshold_tokens_per_hour": 200000,
      "action_on_breach": "switch_to_fallback"
    },
    "claude_opus": {
      "threshold_tokens_per_hour": 50000,
      "action_on_breach": "switch_to_fallback"
    },
    "claude_sonnet": {
      "threshold_tokens_per_hour": 100000,
      "action_on_breach": "switch_to_fallback"
    },
    "gemini_2_5_flash": {
      "threshold_tokens_per_hour": 150000,
      "action_on_breach": "switch_to_fallback"
    },
    "phi_4_mini_local": {
      "threshold": "unlimited",
      "action_on_error": "switch_to_fallback"
    },
    "deepseek_r1_local": {
      "threshold": "unlimited",
      "action_on_error": "switch_to_fallback"
    },
    "qwen3.5_coder_27b_local": {
      "threshold": "unlimited",
      "action_on_error": "switch_to_fallback",
      "note": "Local reasoning model for code generation + technical tasks"
